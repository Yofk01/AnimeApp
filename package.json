{
  "name": "anime-app",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "prestart": "prisma migrate deploy",
    "start": "concurrently -k \"npm:watch:main\" \"npm:serve:renderer\" \"npm:wait:electron\"",
    "wait:electron": "wait-on tcp:4200 dist/main/main.js && cross-env ELECTRON_RENDERER_URL=http://localhost:4200 electron .",
    "serve:renderer": "ng serve --project renderer --host 127.0.0.1 --port 4200",
    "watch:main": "tsc -p tsconfig.main.json --watch",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "ng build --project renderer",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@prisma/client": "^6.8.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.8.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@types/node": "^22.15.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "prisma": "^6.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "wait-on": "^8.0.0"
  }
}
